<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             xmlns:tools="http://schemas.android.com/tools"
                                             android:layout_width="match_parent"
                                             android:layout_height="match_parent" android:background="#ACB6E9" android:backgroundTint="#86FDE8"
>


    <Button
            android:text="Ingresar"
            android:layout_width="210dp"
            android:layout_height="45dp" android:id="@+id/button" tools:layout_editor_absoluteY="119dp"
            tools:layout_editor_absoluteX="235dp" android:backgroundTint="#85B6FF" android:fontFamily="@font/delius"/>
    <Button
            android:text="Crear cuenta"
            android:layout_width="210dp"
            android:layout_height="45dp" android:id="@+id/button2" tools:layout_editor_absoluteY="559dp"
            tools:layout_editor_absoluteX="100dp" android:backgroundTint="#FFFFFF" android:fontFamily="@font/delius"/>
    <EditText
            android:layout_width="260dp"
            android:layout_height="40dp"
            android:inputType="textEmailAddress"
            android:ems="10"
            android:id="@+id/editTextTextEmailAddress" tools:layout_editor_absoluteY="288dp"
            tools:layout_editor_absoluteX="76dp" android:hint="Correo electrónico"/>
    <EditText
            android:layout_width="259dp"
            android:layout_height="40dp"
            android:inputType="textPassword"
            android:ems="10"
            android:id="@+id/editTextTextPassword" tools:layout_editor_absoluteY="357dp"
            tools:layout_editor_absoluteX="76dp" android:hint="Contraseña"/>
    <ImageView
            android:layout_width="200dp"
            android:layout_height="200dp" app:srcCompat="@mipmap/ic_launcher" android:id="@+id/imageView3"
            tools:layout_editor_absoluteY="37dp" tools:layout_editor_absoluteX="103dp"/>
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/textView3" tools:layout_editor_absoluteY="429dp"
            tools:layout_editor_absoluteX="215dp" android:hint="Olvidaste tu contraseña?"/>
</android.support.constraint.ConstraintLayout>